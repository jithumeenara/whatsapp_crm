# ============================================================
# REQUIRED — the app won't start without these.
# ============================================================

# PostgreSQL connection string (local database)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/whatsapp_crm

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# WhatsApp token encryption (64 hex chars = 32 bytes, AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# Meta App Secret (Meta for Developers → App Settings → Basic)
# Verifies the HMAC-SHA256 signature on every inbound webhook POST.
META_APP_SECRET=your-meta-app-secret

# ============================================================
# RECOMMENDED
# ============================================================

# Canonical public URL of this deployment
NEXT_PUBLIC_SITE_URL=https://crm.example.com

# ============================================================
# OPTIONAL
# ============================================================

# Shared secret protecting GET /api/automations/cron
# Required if you use Wait steps in automations
# AUTOMATION_CRON_SECRET=generate-a-long-random-string

# Meta App ID — required for template Resumable Upload
# META_APP_ID=your-meta-app-id

# Skip Meta API calls during local dev / CI for template testing
# WHATSAPP_TEMPLATES_DRY_RUN=true

# RSA-2048 private key for Meta WhatsApp Flows endpoint encryption.
# Required if you use WhatsApp Flows with data_exchange (dynamic data endpoint).
#
# How to generate:
#   openssl genrsa -out flows_private.pem 2048
#   openssl rsa -in flows_private.pem -pubout -out flows_public.pem
#
# 1. Upload flows_public.pem content to: Meta → Your Flow → Settings → Encryption Key
# 2. Set your endpoint URL in: Meta → Your Flow → Settings → Endpoint URI
#    Format: https://your-domain.com/api/flows/<flow-id>/webhook
# 3. Paste the private key below — replace all newlines with \n
#
# FLOWS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"

# Hostname allowlist for invite URLs (comma-separated)
# ALLOWED_INVITE_HOSTS=crm.example.com,crm-staging.example.com

# Server hostname and port
# HOSTNAME=localhost
# PORT=3000
